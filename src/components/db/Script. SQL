-- 1. ESTRUCTURA DE LA BASE DE DATOS (DDL)

CREATE TABLE jugadores (
    id_jugador INT NOT NULL AUTO_INCREMENT,
    nombre VARCHAR(100) NOT NULL,
    posicion VARCHAR(50) NOT NULL,
    dorsal INT,
    estado VARCHAR(20) DEFAULT 'Activo', -- Activo, Lesionado, Suspendido
    asistencia_promedio INT DEFAULT 0,
    PRIMARY KEY (id_jugador)
);

CREATE TABLE asistencia (
    id_asistencia INT NOT NULL AUTO_INCREMENT,
    id_jugador INT NOT NULL,
    fecha DATE NOT NULL,
    tipo_evento VARCHAR(50) NOT NULL, -- Entrenamiento, Partido
    estado_asistencia VARCHAR(20) NOT NULL, -- Presente, Ausente, Justificado
    PRIMARY KEY (id_asistencia),
    FOREIGN KEY (id_jugador) REFERENCES jugadores(id_jugador) ON DELETE CASCADE
);

CREATE TABLE finanzas (
    id_pago INT NOT NULL AUTO_INCREMENT,
    id_jugador INT NOT NULL,
    concepto VARCHAR(100) NOT NULL, -- Cuota Mensual, Cuota Incorporación
    monto INT NOT NULL,
    fecha_pago DATE,
    estado_pago VARCHAR(20) DEFAULT 'Pendiente', -- Pagado, Pendiente
    PRIMARY KEY (id_pago),
    FOREIGN KEY (id_jugador) REFERENCES jugadores(id_jugador) ON DELETE CASCADE
);


